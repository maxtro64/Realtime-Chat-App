# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=YourAppName

# Redis Cache (Optional but recommended for production)
REDIS_URL=redis://default:password@hostname:6379

# JWT Configuration
JWT_SECRET=your_long_random_secret_key_min_32_chars

# Server Configuration
NODE_PORT=5001
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.vercel.app

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
